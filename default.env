BOT_TOKEN=вставь_сюда_токен
WEBHOOK_HOST=
WEBHOOK_SECRET=secret
PORT=8080
METRICS_ADDR=:9090
LOG_LEVEL=info
DB_HOST=db
DB_PORT=5432
DB_USER=maxbot
DB_PASSWORD=maxbot_secret
DB_NAME=maxbot_db
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=10
ENABLE_CACHE=false
RUN_MIGRATIONS=true

# Redis
REDIS_URL=redis://redis:6379/0

# Performance
WORKER_COUNT=0
UPDATE_BUFFER_SIZE=10000
MAX_BACKGROUND_WORKERS=1000

ENABLE_TELEMETRY=false
DEFAULT_MUTE_DURATION=30m
GROUP_LINKED_SUCCESS_TEXT=
MAX_IMPORT_FILE_SIZE=102400
TZ=Europe/Moscow
BOT_OWNER_ID=0

# Toxicity Filter (rubert-tiny-toxicity)
TOXICITY_ENABLED=false
TOXICITY_API_URL=http://toxicity-api:8000
TOXICITY_TIMEOUT_MS=3000
TOXICITY_SCORE_THRESHOLD=0.85
TOXICITY_INSULT_THRESHOLD=0.6
TOXICITY_OBSCENITY_THRESHOLD=0.5
TOXICITY_THREAT_THRESHOLD=0.4

POSTGRES_USER=maxbot
POSTGRES_PASSWORD=maxbot_secret
POSTGRES_DB=maxbot_db

# Monitoring (Grafana)
# GRAFANA_ADMIN_PASSWORD=  # Set a strong password in prod.env
