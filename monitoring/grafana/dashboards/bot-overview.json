{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "title": "Update Processing Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "rate(maxbot_update_processing_duration_seconds_count[5m])",
          "legendFormat": "{{type}} ({{status}})"
        }
      ]
    },
    {
      "title": "Processing Latency (p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, rate(maxbot_update_processing_duration_seconds_bucket[5m]))",
          "legendFormat": "p99 {{type}}"
        }
      ]
    },
    {
      "title": "Bot Actions",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "rate(maxbot_bot_actions_total[5m])",
          "legendFormat": "{{action}}"
        }
      ]
    },
    {
      "title": "Deleted Messages",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "rate(maxbot_deleted_messages_total[5m])",
          "legendFormat": "{{reason}}"
        }
      ]
    },
    {
      "title": "Active Mutes",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 16 },
      "targets": [
        { "expr": "maxbot_active_mutes", "legendFormat": "Mutes" }
      ]
    },
    {
      "title": "Active Goroutines",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 16 },
      "targets": [
        { "expr": "maxbot_active_goroutines", "legendFormat": "Goroutines" }
      ]
    },
    {
      "title": "Background Workers Busy",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 16 },
      "targets": [
        { "expr": "maxbot_background_workers_busy", "legendFormat": "Busy" }
      ]
    },
    {
      "title": "Cache Hit Ratio",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "targets": [
        {
          "expr": "rate(maxbot_cache_hits_total[5m]) / (rate(maxbot_cache_hits_total[5m]) + rate(maxbot_cache_misses_total[5m]))",
          "legendFormat": "{{cache}} hit ratio"
        }
      ]
    },
    {
      "title": "Cache Operations",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "targets": [
        {
          "expr": "rate(maxbot_cache_hits_total[5m])",
          "legendFormat": "{{cache}} hits"
        },
        {
          "expr": "rate(maxbot_cache_misses_total[5m])",
          "legendFormat": "{{cache}} misses"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["maxbot"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "title": "Max Moderation Bot",
  "uid": "maxbot-overview"
}
